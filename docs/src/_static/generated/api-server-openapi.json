{
  "openapi": "3.1.0",
  "info": {
    "title": "API Server",
    "description": "API Server for CLP",
    "contact": {
      "name": "YScope"
    },
    "license": {
      "name": ""
    },
    "version": "0.12.1-dev"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/query": {
      "post": {
        "tags": [],
        "description": "Submits a new query job.",
        "operationId": "query",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryConfig"
              },
              "example": {
                "query_string": "*",
                "datasets": [
                  "default"
                ],
                "time_range_begin_millisecs": 0,
                "time_range_end_millisecs": 17356896,
                "ignore_case": true,
                "max_num_results": 0,
                "buffer_results_in_mongodb": true
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The URI to fetch the results of the submitted query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResultsUri"
                },
                "example": {
                  "query_results_uri": "/query_results/1"
                }
              }
            }
          },
          "500": {
            "description": ""
          }
        }
      }
    },
    "/query/{search_job_id}": {
      "delete": {
        "tags": [],
        "description": "Cancels a previously submitted query job.",
        "operationId": "cancel_query",
        "parameters": [
          {
            "name": "search_job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The cancellation request was submitted successfully."
          },
          "404": {
            "description": "No cancellable query job with the given ID was found."
          },
          "500": {
            "description": ""
          }
        }
      }
    },
    "/query_results/{search_job_id}": {
      "get": {
        "tags": [],
        "description": "Streams the results of a previously submitted query as Server-Sent Events (SSE).",
        "operationId": "query_results",
        "parameters": [
          {
            "name": "search_job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Server-Sent Events stream of query results. Each event contains a single line of the query result in JSON format.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                },
                "example": "data: {\"timestamp\": 1633036800, \"message\": \"Example log message\"}\\n"
              }
            }
          },
          "500": {
            "description": ""
          }
        }
      }
    },
    "/usage/compression": {
      "get": {
        "tags": [],
        "description": "Gets resource usage statistics for compression jobs within the given time range.",
        "operationId": "compression_usage",
        "parameters": [
          {
            "name": "time_range_begin_millisecs",
            "in": "query",
            "description": "Start of usage window (epoch milliseconds, inclusive).",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "time_range_end_millisecs",
            "in": "query",
            "description": "End of usage window (epoch milliseconds, exclusive).",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "job_status",
            "in": "query",
            "description": "Job statuses to include as a comma-separated list (e.g.\n`job_status=succeeded,failed`). Recognized values (case-insensitive):\n`PENDING`, `RUNNING`, `SUCCEEDED`, `FAILED`, `KILLED`.\nDefaults to `SUCCEEDED,FAILED,KILLED` (all terminal states).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of jobs to return. Must be > 0; defaults to 1000.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CompressionUsage"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters (e.g., time_range_begin_millisecs > time_range_end_millisecs, missing required fields)"
          },
          "500": {
            "description": ""
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CompressionJobStatus": {
        "type": "string",
        "enum": [
          "Pending",
          "Running",
          "Succeeded",
          "Failed",
          "Killed"
        ]
      },
      "CompressionUsage": {
        "type": "object",
        "description": "Resource usage statistics for the compression job with the specified ID.",
        "required": [
          "id",
          "job_status",
          "time_creation_millisecs",
          "time_begin_millisecs",
          "uncompressed_size_bytes",
          "compressed_size_bytes",
          "num_tasks"
        ],
        "properties": {
          "compressed_size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Total compressed archive size, in bytes."
          },
          "duration_secs": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Wall-clock duration the job ran, in seconds. Absent if the job did not complete."
          },
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "Compression job ID."
          },
          "job_status": {
            "$ref": "#/components/schemas/CompressionJobStatus",
            "description": "Current status of the job."
          },
          "num_tasks": {
            "type": "integer",
            "format": "int32",
            "description": "Number of tasks the job was split into."
          },
          "tasks_duration_secs": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Sum of all task durations, in seconds. Absent if no tasks reported a duration."
          },
          "time_begin_millisecs": {
            "type": "integer",
            "format": "int64",
            "description": "Time the job started executing (epoch milliseconds)."
          },
          "time_creation_millisecs": {
            "type": "integer",
            "format": "int64",
            "description": "Time the job was created (epoch milliseconds)."
          },
          "uncompressed_size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Total uncompressed size of input files, in bytes."
          }
        }
      },
      "QueryConfig": {
        "type": "object",
        "description": "Defines the request configuration for submitting a search query.",
        "required": [
          "query_string"
        ],
        "properties": {
          "buffer_results_in_mongodb": {
            "type": "boolean",
            "description": "Whether to buffer search results in `MongoDB`.\nBy default, search results are buffered in temporary files. When set to `true`, results\nwill be stored in `MongoDB` instead."
          },
          "datasets": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            },
            "description": "The datasets to search within. If not provided, only `default` dataset will be searched."
          },
          "ignore_case": {
            "type": "boolean",
            "description": "Whether the string match should be case-insensitive."
          },
          "max_num_results": {
            "type": "integer",
            "format": "int32",
            "description": "The maximum number of results to return. Set to `0` for no limit.",
            "minimum": 0
          },
          "query_string": {
            "type": "string",
            "description": "The search query as a KQL string."
          },
          "time_range_begin_millisecs": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "The beginning timestamp (in epoch milliseconds) for the search range (inclusive)."
          },
          "time_range_end_millisecs": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "The ending timestamp (in epoch milliseconds) for the search range (inclusive)."
          }
        },
        "additionalProperties": false
      },
      "QueryResultsUri": {
        "type": "object",
        "required": [
          "query_results_uri"
        ],
        "properties": {
          "query_results_uri": {
            "type": "string",
            "description": "The uri to get the query results."
          }
        },
        "additionalProperties": false
      }
    }
  }
}